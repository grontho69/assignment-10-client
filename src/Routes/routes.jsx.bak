import { createBrowserRouter } from "react-router";
import MainLayout from "../layouts/MainLayout";
import Home from "../pages/Home";
import AllIssues from "../pages/AllIssues";
import IssueDetails from "../pages/IssueDetails";
import Login from "../pages/Login";
import Register from "../pages/Register";
import AddIssues from "../pages/AddIssues";
import MyIssues from "../pages/MyIssues";
import MyContribution from "../pages/MyContribution";
import { PrivateRoute, AdminRoute } from "./ProtectedRoutes";
import Dashboard from "../pages/Dashboard";
import SustainabilityAnalytics from "../pages/SustainabilityAnalytics";
import Users from "../pages/Users";
import Settings from "../pages/Settings";
import api from "../services/api";

const issuesLoader = async () => {
    try {
        const res = await api.get('/issues');
        return res.data;
    } catch (err) {
        return [];
    }
};

const singleIssueLoader = async ({ params }) => {
    try {
        const res = await api.get(`/issues/${params.id}`);
        return res.data;
    } catch (err) {
        return null;
    }
};

export const router = createBrowserRouter([
  {
    path: "/",
    element: <MainLayout />,
    children: [
      {
        path: "/",
        element: <Home />,
        loader: async () => {
            try {
                const res = await api.get('/issues/recent');
                return res.data;
            } catch (err) {
                return [];
            }
        }
      },
      {
        path: "/all-issues",
        element: <AllIssues />,
        loader: issuesLoader
      },
      {
        path: "/reports",
        element: <AllIssues />,
        loader: issuesLoader
      },
      {
        path: '/add-issue',
        element: <PrivateRoute><AddIssues /></PrivateRoute>,
      },
      {
        path: '/issue-details/:id',
        element: <PrivateRoute><IssueDetails /></PrivateRoute>,
        loader: singleIssueLoader
      },
      {
        path: '/my-issues',
        element: <PrivateRoute><MyIssues /></PrivateRoute>,
      },
      {
        path: '/my-contribution',
        element: <PrivateRoute><MyContribution /></PrivateRoute>,
      },
      {
        path: "/analytics",
        element: <PrivateRoute><SustainabilityAnalytics /></PrivateRoute>,
      },
      {
        path: '/login',
        element: <Login />,
      },
      {
        path: '/register',
        element: <Register />,
      },
      {
        path: '/dashboard',
        element: <PrivateRoute><Dashboard /></PrivateRoute>,
      },
      {
        path: '/users',
        element: <AdminRoute><Users /></AdminRoute>,
      },
      {
        path: '/settings',
        element: <PrivateRoute><Settings /></PrivateRoute>,
      }
    ]
  },
  {
    path: "*",
    element: <div className="h-screen flex items-center justify-center flex-col gap-4">
        <h1 className="text-9xl font-black text-emerald-500">404</h1>
        <p className="text-2xl font-bold">Page Not Found</p>
        <button className="btn btn-primary" onClick={() => window.location.href = '/'}>Go Home</button>
    </div>
  }
]);
