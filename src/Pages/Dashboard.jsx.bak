  const { user } = useAuth();
  return (
    <DashboardLayout>
      <div className="space-y-12">
        <header className="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-2">
            <div>
                <motion.h1 
                    initial={{ opacity: 0, x: -20 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ duration: 0.5, ease: "easeOut" }}
                    className="text-4xl font-black text-slate-800 dark:text-white tracking-tight"
                >
                    Citizen <span className="text-emerald-500">Overview</span>
                </motion.h1>
                <p className="text-slate-500 dark:text-gray-400 mt-2 font-medium text-lg capitalize">Welcome back, {user?.name || 'Authorized Member'}</p>
            </div>
        </header>

        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <StatsCard title="Community Reports" value="1,284" icon={FileText} color="bg-emerald-600" trend="up" trendValue="12" />
          <StatsCard title="Verified Citizens" value="8,492" icon={Users} color="bg-blue-600" trend="up" trendValue="08" />
          <StatsCard title="Cleanup Drives" value="142" icon={Activity} color="bg-rose-600" trend="down" trendValue="02" />
          <StatsCard title="Avg Impact Score" value="94.2%" icon={LayoutDashboard} color="bg-slate-900" trend="up" trendValue="14" />
        </div>

        <div className="grid grid-cols-1 xl:grid-cols-3 gap-12">
            <div className="xl:col-span-2 bg-white dark:bg-gray-900 rounded-[3.5rem] p-10 lg:p-14 shadow-sm border border-slate-50 dark:border-gray-800 relative overflow-hidden">
                <EmissionChart />
            </div>
        </div>
        <div className="pt-4">
            <RecentReportsTable />
        </div>
      </div>
    </DashboardLayout>
  );
